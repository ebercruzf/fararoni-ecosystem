    <!-- Plugin Management - Configuración común para todos los módulos -->
    <build>
        <pluginManagement>
            <plugins>
                <!-- Maven Compiler Plugin -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>${maven-compiler-plugin.version}</version>
                    <configuration>
                        <!-- Java 25 with Preview Features: use release instead of source/target -->
                        <release>${java.version}</release>
                        <!-- Java 25 Preview Features: StructuredTaskScope (JEP 480), ScopedValues (JEP 481) -->
                        <compilerArgs>
                            <arg>--enable-preview</arg>
                        </compilerArgs>
                        <annotationProcessorPaths>
                            <path>
                                <groupId>info.picocli</groupId>
                                <artifactId>picocli-codegen</artifactId>
                                <version>${picocli.version}</version>
                            </path>
                        </annotationProcessorPaths>
                    </configuration>
                </plugin>

                <!-- Maven Shade Plugin -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-shade-plugin</artifactId>
                    <version>${maven-shade-plugin.version}</version>
                </plugin>

                <!-- Maven Surefire Plugin (Testing) -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>${maven-surefire-plugin.version}</version>
                    <configuration>
                        <includes>
                            <include>**/*Test.java</include>
                            <include>**/*Tests.java</include>
                        </includes>
                        <argLine>
                            --enable-preview
                            -XX:+EnableDynamicAgentLoading
                            --add-opens java.base/java.lang=ALL-UNNAMED
                            --add-opens java.base/java.lang.reflect=ALL-UNNAMED
                            ${argLine}
                        </argLine>
                    </configuration>
                </plugin>

                <!-- Maven Source Plugin -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-source-plugin</artifactId>
                    <version>${maven-source-plugin.version}</version>
                    <executions>
                        <execution>
                            <id>attach-sources</id>
                            <goals>
                                <goal>jar</goal>
                            </goals>
                        </execution>
                    </executions>
                </plugin>

                <!-- Maven Javadoc Plugin -->
                <!-- IMPORTANTE: Requiere enable-preview porque el código usa JEP 480/481 -->
                <!-- Ver: docs/arquitectura/warnings/FASE-47-CRITICAL-ENABLE-PREVIEW-REQUIRED.md -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-javadoc-plugin</artifactId>
                    <version>${maven-javadoc-plugin.version}</version>
                    <configuration>
                        <source>${java.version}</source>
                        <!-- Preview features: StructuredTaskScope (JEP 480), ScopedValue (JEP 481) -->
                        <additionalOptions>
                            <additionalOption>--enable-preview</additionalOption>
                        </additionalOptions>
                        <detectJavaApiLink>false</detectJavaApiLink>
                        <failOnError>false</failOnError>
                        <!-- Disable strict HTML validation for Javadoc -->
                        <doclint>none</doclint>
                    </configuration>
                    <executions>
                        <execution>
                            <id>attach-javadocs</id>
                            <goals>
                                <goal>jar</goal>
                            </goals>
                        </execution>
                    </executions>
                </plugin>

                <!-- JaCoCo Code Coverage -->
                <plugin>
                    <groupId>org.jacoco</groupId>
                    <artifactId>jacoco-maven-plugin</artifactId>
                    <version>${jacoco-maven-plugin.version}</version>
                    <executions>
                        <execution>
                            <goals>
                                <goal>prepare-agent</goal>
                            </goals>
                        </execution>
                        <execution>
                            <id>report</id>
                            <phase>test</phase>
                            <goals>
                                <goal>report</goal>
                            </goals>
                        </execution>
                    </executions>
                </plugin>

                <!-- GraalVM Native Image -->
                <plugin>
                    <groupId>org.graalvm.buildtools</groupId>
                    <artifactId>native-maven-plugin</artifactId>
                    <version>${graalvm-plugin.version}</version>
                </plugin>

                <!-- =============================================
                     LICENSE HEADER PLUGIN
                     Gestiona headers de licencia en archivos fuente.

                     Todos los modulos: Apache-2.0 (LICENSE-HEADER-APACHE2.txt)

                     Comandos (ejecutar desde cada modulo):
                       mvn license:check   - Verificar (CI/CD)
                       mvn license:format  - Agregar/actualizar headers
                       mvn license:remove  - Quitar headers
                     ============================================= -->
                <plugin>
                    <groupId>com.mycila</groupId>
                    <artifactId>license-maven-plugin</artifactId>
                    <version>${license-maven-plugin.version}</version>
                    <configuration>
                        <!-- Header por defecto: Apache 2.0 (modulos open source) -->
                        <header>${license.header.basedir}/LICENSE-HEADER-APACHE2.txt</header>
                        <properties>
                            <year>2026</year>
                            <owner>Fararoni</owner>
                            <email>dev@fararoni.dev</email>
                        </properties>
                        <includes>
                            <include>**/*.java</include>
                        </includes>
                        <excludes>
                            <exclude>**/package-info.java</exclude>
                            <exclude>**/module-info.java</exclude>
                            <exclude>**/target/**</exclude>
                            <exclude>**/.idea/**</exclude>
                            <exclude>**/node_modules/**</exclude>
                        </excludes>
                        <mapping>
                            <java>SLASHSTAR_STYLE</java>
                        </mapping>
                        <strictCheck>true</strictCheck>
                        <skipExistingHeaders>false</skipExistingHeaders>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>

