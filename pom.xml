        <!-- =============================================
             NATIVE PROFILE - GraalVM Native Image
             Compila binarios nativos sin necesidad de JVM.
             Usa: mvn -Pnative package -pl fararoni-core
                  mvn -Pnative package -pl fararoni-enterprise
             ============================================= -->
        <profile>
            <id>native</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.graalvm.buildtools</groupId>
                        <artifactId>native-maven-plugin</artifactId>
                        <version>${graalvm-plugin.version}</version>
                        <extensions>true</extensions>
                        <executions>
                            <execution>
                                <id>build-native</id>
                                <goals>
                                    <goal>compile-no-fork</goal>
                                </goals>
                                <phase>package</phase>
                            </execution>
                        </executions>
                        <configuration>
                            <!-- Nombre del binario generado -->
                            <imageName>${project.artifactId}</imageName>

                            <!-- Clase principal (se sobreescribe en cada módulo) -->
                            <mainClass>dev.fararoni.core.FararoniMain</mainClass>

                            <!-- Flags de compilación -->
                            <buildArgs>
                                <buildArg>--no-fallback</buildArg>
                                <buildArg>--enable-url-protocols=http,https</buildArg>
                                <buildArg>-H:+UnlockExperimentalVMOptions</buildArg>

                                <!-- =============================================
                                     INCLUDE-RESOURCES: Librerías nativas embebidas

                                     Para que el binario nativo sea auto-contenido,
                                     incluimos las librerías .dylib/.so/.dll dentro
                                     del ejecutable. NativeLoader las extrae en runtime.

                                     Sin esto, el binario no puede usar el modelo local.
                                     ============================================= -->
                                <buildArg>-H:IncludeResources=.*\.dylib$</buildArg>
                                <buildArg>-H:IncludeResources=.*\.so$</buildArg>
                                <buildArg>-H:IncludeResources=.*\.dll$</buildArg>
                                <!-- JNA resource bundles -->
                                <buildArg>-H:IncludeResourceBundles=com.sun.jna.resources.jna</buildArg>

                                <!-- =============================================
                                     EXCLUDE-CONFIG: Solución para SQLite JDBC

                                     El JAR de SQLite y el shaded JAR de fararoni-core
                                     contienen META-INF/native-image/org.xerial/sqlite-jdbc/
                                     native-image.properties que referencia:
                                     "org.sqlite.nativeimage.SqliteJdbcFeature"

                                     Esta clase Feature no existe en el classpath de build
                                     y causa el error:
                                     "Feature org.sqlite.nativeimage.SqliteJdbcFeature
                                      class not found"

                                     La solución es excluir esa configuración rota y
                                     dejar que el metadataRepository provea la correcta.
                                     ============================================= -->
                                <!-- Excluir configuración CORRUPTA de org.xerial dentro del shaded JAR -->
                                <buildArg>--exclude-config</buildArg>
                                <buildArg>fararoni-core-.*\.jar</buildArg>
                                <buildArg>META-INF/native-image/org\.xerial/.*</buildArg>

                                <!-- =============================================
                                     MONOLITO MODULAR: Todo en un binario

                                     Usamos LlamaSubstitutions.java para "lobotomizar"
                                     la carga de librerias nativas en build-time.
                                     Esto permite incluir java-llama.cpp en el binario
                                     sin causar Exit 139.

                                     Ver: docs/NATIVE_IMAGE_ARCHITECTURE.md (PARTE II)
                                     ============================================= -->
                                <!-- Clases de llama.cpp deben inicializarse en runtime -->
                                <buildArg>--initialize-at-run-time=de.kherud.llama</buildArg>
                                <!-- JNA aun necesita inicializacion en runtime -->
                                <buildArg>--initialize-at-run-time=com.sun.jna</buildArg>

                                <!-- =============================================
                                     JACKSON TIMEZONE FIX

                                     Jackson's StdDateFormat usa SimpleDateFormat en
                                     su static initializer, que necesita TimeZone.

                                     Forzamos la inicializacion en build-time para
                                     evitar el error:
                                     "Could not determine current working directory"
                                     ============================================= -->
                                <buildArg>--initialize-at-build-time=com.fasterxml.jackson.databind.util.StdDateFormat</buildArg>

                                <!-- =============================================
                                     SQLITE GRAALVM 25 FIX (2026-01-29)

                                     SQLite JDBC usa ProcessRunner para detectar
                                     el entorno (Android Termux). En GraalVM 25,
                                     esta clase debe inicializarse en build-time.
                                     ============================================= -->
                                <buildArg>--initialize-at-build-time=org.sqlite.util.ProcessRunner</buildArg>
                                <buildArg>--initialize-at-build-time=org.sqlite.util.OSInfo</buildArg>

                                <!-- Reportar errores detallados -->
                                <buildArg>-H:+ReportExceptionStackTraces</buildArg>
                            </buildArgs>

                            <!-- =============================================
                                 METADATA REPOSITORY - Solución Enterprise-Grade

                                 Descarga automáticamente configuraciones de
                                 reflection/jni/resources probadas por la comunidad
                                 para librerías problemáticas como SQLite JDBC.

                                 Esto evita el error:
                                 "Feature org.sqlite.nativeimage.SqliteJdbcFeature
                                  class not found"

                                 El repositorio es mantenido por Oracle/GraalVM:
                                 https://github.com/oracle/graalvm-reachability-metadata
                                 ============================================= -->
                            <metadataRepository>
                                <enabled>true</enabled>
                            </metadataRepository>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

    <!-- Repositories (for pty4j from JetBrains) -->
    <repositories>
        <repository>
            <id>jetbrains-intellij-dependencies</id>
            <url>https://packages.jetbrains.team/maven/p/ij/intellij-dependencies</url>
        </repository>
    </repositories>

    <!-- Distribution Management -->
    <distributionManagement>
        <snapshotRepository>
            <id>ossrh</id>
            <url>https://oss.sonatype.org/content/repositories/snapshots</url>
        </snapshotRepository>
        <repository>
            <id>ossrh</id>
            <url>https://oss.sonatype.org/service/local/staging/deploy/maven2/</url>
        </repository>
    </distributionManagement>
</project>
