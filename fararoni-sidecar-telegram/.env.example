# =============================================================================
# FARARONI SIDECAR - TELEGRAM
# FASE 71.5 - Configuracion de variables de entorno
# =============================================================================
#
# Instrucciones:
# 1. Copia este archivo a .env: cp .env.example .env
# 2. Edita .env con tus valores
# 3. O exporta las variables directamente: export TELEGRAM_TOKEN="..."
#
# =============================================================================

# -----------------------------------------------------------------------------
# TOKEN DEL BOT DE TELEGRAM (OBLIGATORIO)
# -----------------------------------------------------------------------------
# Obtener de @BotFather en Telegram:
# 1. Abre Telegram y busca @BotFather
# 2. Envia /newbot
# 3. Sigue las instrucciones
# 4. Copia el token aqui
#
TELEGRAM_TOKEN=1234567890:AAH_tu_token_aqui

# -----------------------------------------------------------------------------
# PUERTO DEL SERVIDOR HTTP (OPCIONAL)
# -----------------------------------------------------------------------------
# Puerto donde el sidecar escucha peticiones del Gateway
# Default: 3001
#
SIDECAR_PORT=3001

# -----------------------------------------------------------------------------
# URL DEL GATEWAY REST (OPCIONAL)
# -----------------------------------------------------------------------------
# URL del endpoint Ingress del Gateway de Fararoni
# Default: http://localhost:7071/gateway/v1/inbound
#
GATEWAY_URL=http://localhost:7071/gateway/v1/inbound

# -----------------------------------------------------------------------------
# MODO DEBUG (OPCIONAL)
# -----------------------------------------------------------------------------
# Habilita logs adicionales para debugging
# Valores: true / false
# Default: false
#
DEBUG=false
