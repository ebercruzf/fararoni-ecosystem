# =============================================================================
# FARARONI SUITE v1.0.0 - Configuracion Global
# =============================================================================
# Este archivo centraliza las variables de entorno para todos los componentes.
# El installer.sh lo edita automaticamente al configurar credenciales.
# =============================================================================

# --- CORE ---
# Servidor LLM (OpenAI-compatible API)
# Ollama: http://localhost:11434 | vLLM: http://localhost:8000
SERVER_URL=http://localhost:11434
MODEL_NAME=qwen2.5-coder
#API_KEY=sk-xxxxxxxx

# --- GATEWAY ---
GATEWAY_PORT=7071
GATEWAY_URL=http://localhost:7071/gateway/v1/inbound

# --- SIDECAR: TELEGRAM ---
# Obtener en @BotFather: https://core.telegram.org/bots#how-do-i-create-a-bot
#TELEGRAM_TOKEN=

# --- SIDECAR: DISCORD ---
# Obtener en: https://discord.com/developers/applications
# IMPORTANTE: Activar "Message Content Intent" en Privileged Intents
#DISCORD_TOKEN=

# --- SIDECAR: WHATSAPP ---
# No requiere token. Escanea QR al iniciar (Baileys).

# --- SIDECAR: iMESSAGE ---
# Requiere BlueBubbles Server (solo macOS): https://bluebubbles.app/
#BLUEBUBBLES_PASSWORD=
#BLUEBUBBLES_URL=http://localhost:1234

# --- NATS (Enterprise) ---
NATS_URL=nats://localhost:4222
