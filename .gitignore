# =============================================================================
# FARARONI ECOSYSTEM — Master .gitignore
# =============================================================================

# =============================================================================
# Java / Maven / Gradle
# =============================================================================
target/
build/
.gradle/
*.class
*.jar
*.war
*.ear
*.log
dependency-reduced-pom.xml
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# =============================================================================
# Node.js / npm (Sidecars)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm
dist/

# =============================================================================
# Credenciales y Secrets (CRITICO — nunca subir)
# =============================================================================
.env
.env.local
.env.production
.env.*.local
*.pem
*.key
*.p12
credentials.json
service-account.json
baileys_auth_info/

# =============================================================================
# GraalVM Native Image
# =============================================================================
*.o
*.so
*.dylib
*.dll
graalvm-reachability-metadata/

# =============================================================================
# SEA Build (Node.js Single Executable)
# =============================================================================
fararoni-distribution/target/
fararoni-distribution/target/sidecars/
fararoni-distribution/target/sea-node/
**/dist/sea-prep.blob
**/dist/bundle.js
**/dist/sea-config.json

# =============================================================================
# IDE
# =============================================================================
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.project
.classpath
*.swp
*.swo
*~
.factorypath

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# =============================================================================
# Linux
# =============================================================================
*~
.fuse_hidden*
.nfs*

# =============================================================================
# Windows
# =============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# =============================================================================
# Logs
# =============================================================================
logs/
*.log

# =============================================================================
# Archivos temporales de proyecto
# =============================================================================
commit-msg.txt
cleanup_log.md
deploy_protocol.sh

# =============================================================================
# Temporales
# =============================================================================
tmp/
temp/
*.tmp
*.bak
*.orig

# =============================================================================
# DMG / Instaladores generados
# =============================================================================
*.dmg
*.pkg
*.msi
