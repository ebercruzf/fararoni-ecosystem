# =============================================================================
# FARARONI SIDECAR - DISCORD
# Configuracion de variables de entorno
# =============================================================================

# Token del bot de Discord (REQUERIDO)
# Obtenerlo en: https://discord.com/developers/applications
# 1. Crear "New Application"
# 2. Ir a seccion "Bot"
# 3. IMPORTANTE: Activar "Message Content Intent"
# 4. Copiar el token
DISCORD_TOKEN=tu_token_de_discord_aqui

# URL del Gateway REST de Fararoni
# Por defecto: http://localhost:7071/gateway/v1/inbound
GATEWAY_URL=http://localhost:7071/gateway/v1/inbound

# Puerto del servidor HTTP para Egress
# Por defecto: 3002
SIDECAR_PORT=3002

# Permitir mensajes en servidores/guilds (requiere mencion del bot)
# true = responder en servidores si mencionan al bot
# false = solo responder en DMs (mensajes directos)
# Por defecto: false
ALLOW_GUILDS=false

# Lista de IDs de usuarios permitidos (separados por coma)
# Dejar vacio para permitir todos
# Ejemplo: ALLOWED_USERS=123456789012345678,987654321098765432
ALLOWED_USERS=

# Modo debug (muestra logs adicionales)
# true = mostrar logs de debug
# false = solo logs normales
DEBUG=false

# =============================================================================
# COMO INVITAR EL BOT A TU SERVIDOR
# =============================================================================
# 1. Ve a Discord Developer Portal -> Tu App -> OAuth2 -> URL Generator
# 2. Selecciona scopes:
#    - bot
# 3. Selecciona permisos:
#    - Send Messages
#    - Read Message History
#    - View Channels
# 4. Copia la URL generada y abrela en tu navegador
# 5. Selecciona el servidor donde quieres agregar el bot

# =============================================================================
# IMPORTANTE: MESSAGE CONTENT INTENT
# =============================================================================
# Si el bot no puede leer los mensajes, verifica que:
# 1. En Discord Developer Portal -> Tu App -> Bot
# 2. Baja hasta "Privileged Gateway Intents"
# 3. Activa "MESSAGE CONTENT INTENT"
# Sin esto, el bot recibira mensajes vacios
