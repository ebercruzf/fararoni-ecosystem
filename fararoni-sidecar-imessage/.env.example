# =============================================================================
# FARARONI SIDECAR - iMESSAGE (via BlueBubbles)
# Configuracion de variables de entorno
# =============================================================================

# Password del servidor BlueBubbles (REQUERIDO)
# Obtenerlo en: BlueBubbles Server -> API & Webhooks -> Server Password
BLUEBUBBLES_PASSWORD=tu_password_de_bluebubbles_aqui

# URL del servidor BlueBubbles
# Por defecto: http://localhost:1234
BLUEBUBBLES_URL=http://localhost:1234

# URL del Gateway REST de Fararoni
# Por defecto: http://localhost:7071/gateway/v1/inbound
GATEWAY_URL=http://localhost:7071/gateway/v1/inbound

# Puerto del servidor HTTP para Ingress/Egress
# Por defecto: 3003
SIDECAR_PORT=3003

# Lista de numeros de telefono permitidos (separados por coma)
# Dejar vacio para permitir todos
# Ejemplo: ALLOWED_SENDERS=+521234567890,+529876543210
ALLOWED_SENDERS=

# Modo debug (muestra logs adicionales)
# true = mostrar logs de debug
# false = solo logs normales
DEBUG=false

# =============================================================================
# CONFIGURACION DE BLUEBUBBLES SERVER
# =============================================================================
# Antes de usar este sidecar, debes configurar BlueBubbles:
#
# 1. Instalar BlueBubbles Server en tu Mac
#    https://bluebubbles.app/
#
# 2. Conectar con tu cuenta de iMessage (iCloud)
#
# 3. En BlueBubbles -> API & Webhooks:
#    - Copiar el "Server Password" (para BLUEBUBBLES_PASSWORD)
#    - Anotar el puerto (por defecto 1234)
#
# 4. Configurar Webhook:
#    - URL: http://localhost:3003/webhook
#    - Eventos: Seleccionar "New Messages"
#
# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================
#
# - Este sidecar SOLO funciona en macOS
# - Requiere una Mac con iMessage configurado
# - BlueBubbles debe estar corriendo para enviar/recibir mensajes
# - Los mensajes SMS tambien son soportados si tu Mac los recibe
#
